# Copy to .env.local — do not commit .env.local

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Supabase (Dashboard → Settings → API). Prefer anon key; service_role only for hackathon demos.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional if RLS blocks reads:
# NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=

# John orchestrator (must match backend .env)
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_ORCHESTRATOR_WEBHOOK_SECRET=

NEXT_PUBLIC_BASE_PATH=
AUTH_DEBUG=true
