# ===================================================================
#      AUTOPILOT COMMAND CENTER - ENVIRONMENT CONFIGURATION
# -------------------------------------------------------------------
#  Copy this file to .env to get started.
#  Defaults work out of the box — just run: make up
# ===================================================================

# ------------------------------------------------------------
# BACKEND
# ------------------------------------------------------------
APP_ENV=development
FRONTEND_URL=http://localhost:3001
LOG_LEVEL=INFO

# Auth bypass — all requests auto-authenticated as Dev User (admin role)
AUTH_BYPASS=true

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=app_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ------------------------------------------------------------
# FRONTEND
# ------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_BASE_PATH=

# NextAuth (required for session management even with AUTH_BYPASS)
NEXTAUTH_URL=http://localhost:3001

# REQUIRED: A secret used to sign and encrypt NextAuth.js tokens.
# Generate with:
#   macOS/Linux: openssl rand -base64 32
#   Windows:     [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
NEXTAUTH_SECRET=

# ------------------------------------------------------------
# ACELINK — LOCAL JOHN ORCHESTRATOR
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Supervity Auto — operator workflow IDs (from auto.supervity.ai)
WORKFLOW_SVC_URL=https://auto-workflow-api.supervity.ai
SUPERVITY_API_TOKEN=
SUPERVITY_EXECUTE_PATH=/api/v1/workflow-runs/execute/stream
SUPERVITY_SOURCE_HEADER=v1
SUPERVITY_ACTIVE_ORG=AceLink Software Solutions Pvt LTD
SUPERVITY_WORKFLOW_JACK=
SUPERVITY_WORKFLOW_JIM=
SUPERVITY_WORKFLOW_JENNIE=
SUPERVITY_WORKFLOW_JASON=
SUPERVITY_WORKFLOW_GAP=
# Consolidated agents (optional — fallback to JACK/JIM/JENNIE/JASON if empty)
SUPERVITY_WORKFLOW_CRM=
SUPERVITY_WORKFLOW_EMAIL=
SUPERVITY_WORKFLOW_LEGAL=
SUPERVITY_WORKFLOW_PAYMENT=
# Agent E — on-demand monitor (legal replies + silence + OCR). No cron.
SUPERVITY_WORKFLOW_CHECK=
# Optional RAG playbook
SUPERVITY_WORKFLOW_RAG=
SUPERVITY_MOCK_MODE=true

# Optional: Groq / OpenRouter / Ollama (OpenAI-compatible)
LLM_ENABLED=false
LLM_API_URL=https://api.groq.com/openai
LLM_API_KEY=
LLM_MODEL=llama-3.1-8b-instant

# true = create lead in Supabase from John (recommended). false = call Auto Agent A first.
ORCHESTRATOR_CRM_LOCAL_FIRST=true

# Webhook from Max chat — REQUIRED when API is public (ngrok/Railway)
# Teammate sends header: X-Webhook-Secret: <this value>
ORCHESTRATOR_WEBHOOK_SECRET=
# After ngrok: https://xxxx.ngrok-free.app — share with teammate as BASE URL
# ORCHESTRATOR_PUBLIC_URL=
SUPERVITY_POLL_SECONDS=2
SUPERVITY_POLL_MAX_ATTEMPTS=60

# ------------------------------------------------------------
# DOCKER
# ------------------------------------------------------------
# "dev" = hot reload | "prod" = optimized build
FRONTEND_TARGET=dev
